# =========================================================================
# MAX University Event Bot — пример переменных окружения
#
# Скопируй файл: cp .env.example .env
# Заполни реальными значениями. .env в репозиторий НЕ коммитим (см. .gitignore).
# =========================================================================

# === MAX Bot ===
MAX_BOT_TOKEN=replace_me                 # токен из кабинета MAX / MasterBot
MAX_BOT_MODE=longpoll                    # longpoll | webhook
MAX_BOT_WEBHOOK_URL=                     # https://your-domain.com/webhook/max (только для mode=webhook)
MAX_BOT_WEBHOOK_SECRET=                  # 5..256 символов [a-zA-Z0-9_-] — проверка X-Max-Bot-Api-Secret
MAX_BOT_HTTP_TIMEOUT=30s
MAX_BOT_DEBUG=false
MAX_BOT_DEV_SKIP_PING=false              # DEV-only: пропустить MAX ping, long-poll и scheduler.
                                         # Включай ТОЛЬКО для локальной отладки веб-админки без живого токена.
                                         # В проде ВСЕГДА false.

# === HTTP-сервер бота (webhook + healthz) ===
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s

# === Admin REST API (День 13+) ===
ADMIN_API_ADDR=:8081
ADMIN_WEB_BASE_URL=http://localhost:3000
ADMIN_SESSION_KEY=replace_me_with_openssl_rand_base64_32   # HMAC ключ для magic + session JWT

# === Database ===
DATABASE_URL=postgres://app:app@localhost:5432/maxbot?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2

# === Логирование ===
LOG_LEVEL=info                           # debug | info | warn | error
LOG_FORMAT=json                          # json | text

# === GigaChat (День 16+) ===
GIGACHAT_AUTH_KEY=                       # base64 client_id:client_secret из ЛК
GIGACHAT_SCOPE=GIGACHAT_API_PERS         # GIGACHAT_API_PERS | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_MODEL=GigaChat
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_TIMEOUT=20s
GIGACHAT_CA_BUNDLE_FILE=deployments/certs/gigachat_ca_bundle.crt
GIGACHAT_INSECURE_TLS=false              # true ТОЛЬКО на dev, никогда в prod

# === Бизнес-настройки ===
DEFAULT_EVENT_REMINDER_HOURS=24,1        # CSV часов до старта для напоминаний
ORGANIZER_USER_IDS=                      # CSV max_user_id с ролью organizer (ведёт события, НЕ сканирует QR)
STAFF_USER_IDS=                          # CSV max_user_id с ролью staff (волонтёр на входе — QR check-in)
ADMIN_USER_IDS=                          # CSV max_user_id с ролью admin (полный доступ)
WAITLIST_ENABLED=true
WAITLIST_AUTO_PROMOTE=true
NOTIFICATION_BATCH_SIZE=50
NOTIFICATION_RATE_LIMIT_RPS=20           # MAX лимит 30 rps, оставляем запас

# === AI feature flags ===
AI_EVENT_RECOMMENDER_ENABLED=true
AI_NOTIFICATION_REWRITER_ENABLED=true
AI_ORGANIZER_SUMMARY_ENABLED=true
AI_FAQ_ENABLED=false                     # P2
AI_REQUEST_TIMEOUT=15s
AI_MAX_TOKENS=512

# === Policy ===
PRIVACY_POLICY_VERSION=2026-01-v1        # фиксируется в users.consent_policy_ver
