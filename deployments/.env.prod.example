# =============================================================================
# .env.prod — переменные окружения для PRODUCTION
#
# Скопируй: cp deployments/.env.prod.example .env.prod
# Заполни все поля. .env.prod в репозиторий НЕ коммитим.
# =============================================================================

# ── Домен ────────────────────────────────────────────────────────────────────
# Caddy получит TLS-сертификат автоматически через Let's Encrypt.
DOMAIN=bot.youruniversity.ru

# ── PostgreSQL (только внутри Docker-сети, наружу не выходит) ────────────────
POSTGRES_USER=maxbot
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=maxbot

# ── MAX Bot ──────────────────────────────────────────────────────────────────
MAX_BOT_TOKEN=CHANGE_ME
MAX_BOT_MODE=webhook
MAX_BOT_WEBHOOK_URL=https://${DOMAIN}/webhook/max
MAX_BOT_WEBHOOK_SECRET=CHANGE_ME_random_32chars
MAX_BOT_HTTP_TIMEOUT=30s
MAX_BOT_DEBUG=false
MAX_BOT_DEV_SKIP_PING=false

# ── HTTP-сервер ───────────────────────────────────────────────────────────────
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s

# ── Admin API ─────────────────────────────────────────────────────────────────
ADMIN_API_ADDR=:8081
ADMIN_WEB_BASE_URL=https://${DOMAIN}
# Генерировать: openssl rand -base64 32
ADMIN_SESSION_KEY=CHANGE_ME_openssl_rand_base64_32

# ── Database URL (Docker-internal) ───────────────────────────────────────────
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2

# ── Логирование ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── GigaChat (опционально) ────────────────────────────────────────────────────
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_TIMEOUT=20s
GIGACHAT_INSECURE_TLS=false

# ── Бизнес-настройки ─────────────────────────────────────────────────────────
DEFAULT_EVENT_REMINDER_HOURS=24,1
WAITLIST_ENABLED=true
WAITLIST_AUTO_PROMOTE=true
NOTIFICATION_BATCH_SIZE=50
NOTIFICATION_RATE_LIMIT_RPS=20

# ── Роли (MAX user_id через запятую) ─────────────────────────────────────────
# Добавляются при старте. Дальнейшее управление — через веб-панель /users.
ADMIN_USER_IDS=
ORGANIZER_USER_IDS=
STAFF_USER_IDS=

# ── AI feature flags ──────────────────────────────────────────────────────────
AI_EVENT_RECOMMENDER_ENABLED=true
AI_NOTIFICATION_REWRITER_ENABLED=true
AI_ORGANIZER_SUMMARY_ENABLED=true
AI_FAQ_ENABLED=false
AI_REQUEST_TIMEOUT=15s
AI_MAX_TOKENS=512

# ── Policy ────────────────────────────────────────────────────────────────────
PRIVACY_POLICY_VERSION=2026-01-v1
