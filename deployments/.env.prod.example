# =============================================================================
# .env.prod — production environment variables
#
# Copy: cp deployments/.env.prod.example .env.prod
# Fill all fields. .env.prod is NOT committed to git.
# =============================================================================

# ── Domain or IP address ───────────────────────────────────────────────────────
# Just set DOMAIN — everything else is auto-detected:
#   IP address  → HTTP, longpoll, port 80
#   Domain name → HTTPS (Let's Encrypt), webhook, ports 80+443
DOMAIN=1.2.3.4

# —— Prebuilt images (optional override) —————————————————————————————————————————————
# deploy.sh автоматически ставит IMAGE_TAG=current git commit.
# APP_IMAGE/WEB_IMAGE можно переопределить, если registry или имена пакетов другие.
APP_IMAGE=ghcr.io/zhaba1337228/max-university-event-bot-app
WEB_IMAGE=ghcr.io/zhaba1337228/max-university-event-bot-web
IMAGE_TAG=

# ── PostgreSQL (internal only, not exposed) ────────────────────────────────────
POSTGRES_USER=maxbot
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=maxbot

# ── MAX Bot ────────────────────────────────────────────────────────────────────
MAX_BOT_TOKEN=CHANGE_ME

# Bot mode — auto-set by deploy.sh based on DOMAIN:
#   IP     → longpoll (forced, webhook needs HTTPS)
#   Domain → webhook (optimal with HTTPS, set to longpoll if you prefer)
# Override only if you know what you're doing:
MAX_BOT_MODE=longpoll

# Webhook (only if MAX_BOT_MODE=webhook):
MAX_BOT_WEBHOOK_URL=
MAX_BOT_WEBHOOK_SECRET=CHANGE_ME_random_32chars
MAX_BOT_HTTP_TIMEOUT=30s
MAX_BOT_DEBUG=false
MAX_BOT_DEV_SKIP_PING=false

# ── HTTP server ────────────────────────────────────────────────────────────────
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s

# ── Admin API ──────────────────────────────────────────────────────────────────
ADMIN_API_ADDR=:8081
# Auto-derived from DOMAIN. Override only if needed:
ADMIN_WEB_BASE_URL=http://${DOMAIN}
# Generate: openssl rand -base64 32
ADMIN_SESSION_KEY=CHANGE_ME_openssl_rand_base64_32

# ── Database URL (Docker-internal) ─────────────────────────────────────────────
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── GigaChat (optional) ───────────────────────────────────────────────────────
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_TIMEOUT=20s
GIGACHAT_CA_BUNDLE_FILE=/app/certs/gigachat_ca_bundle.crt
GIGACHAT_CA_BUNDLE_HOST_DIR=/opt/app/secrets/gigachat
GIGACHAT_INSECURE_TLS=false

# ── Business settings ─────────────────────────────────────────────────────────
DEFAULT_EVENT_REMINDER_HOURS=24,1
WAITLIST_ENABLED=true
WAITLIST_AUTO_PROMOTE=true
NOTIFICATION_BATCH_SIZE=50
NOTIFICATION_RATE_LIMIT_RPS=20

# ── Roles (MAX user_id, comma-separated) ──────────────────────────────────────
# Added on startup. Further management via web panel /users.
ADMIN_USER_IDS=
ORGANIZER_USER_IDS=
STAFF_USER_IDS=

# ── AI feature flags ───────────────────────────────────────────────────────────
AI_EVENT_RECOMMENDER_ENABLED=true
AI_NOTIFICATION_REWRITER_ENABLED=true
AI_ORGANIZER_SUMMARY_ENABLED=true
AI_FAQ_ENABLED=false
AI_REQUEST_TIMEOUT=15s
AI_MAX_TOKENS=512

# ── Policy ─────────────────────────────────────────────────────────────────────
PRIVACY_POLICY_VERSION=2026-01-v1
