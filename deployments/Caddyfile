# =============================================================================
# Caddyfile — production reverse proxy для MAX University Event Bot
#
# Режимы:
#   HTTP (IP или домен без TLS) — работает из коробки:
#     DOMAIN=1.2.3.4   или   DOMAIN=bot.youruniversity.ru
#
#   HTTPS (только с доменом + Let's Encrypt):
#     Убери "http://" из строки ниже — Caddy автоматически получит сертификат.
#     Нужен: домен → IP, порт 80 и 443 открыты.
#
# Маршрутизация:
#   http://{DOMAIN}/              → Next.js admin panel (web:3000)
#   http://{DOMAIN}/api/*         → Next.js → bot:8081 (через rewrite)
#   http://{DOMAIN}/webhook/max   → Go-бот (bot:8080)
#   http://{DOMAIN}/healthz       → Go-бот (bot:8080)
# =============================================================================

# "http://" перед доменом = форсированный HTTP, без TLS-сертификата.
# Работает как с доменом, так и с IP-адресом.
# Убери "http://" чтобы включить автоматический HTTPS (нужен настоящий домен).
http://{$DOMAIN} {

  # ── Webhook MAX-бота ────────────────────────────────────────────────────
  handle /webhook/* {
    reverse_proxy bot:8080 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
    }
  }

  # ── Healthcheck ──────────────────────────────────────────────────────────
  handle /healthz {
    reverse_proxy bot:8080
  }

  # ── Всё остальное → Next.js ─────────────────────────────────────────────
  handle {
    reverse_proxy web:3000 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
    }
  }

  # ── Логи ─────────────────────────────────────────────────────────────────
  log {
    output stdout
    format json
    level  INFO
  }

  # ── Заголовки безопасности (HTTP-совместимые) ────────────────────────────
  header {
    X-Frame-Options        "SAMEORIGIN"
    X-Content-Type-Options "nosniff"
    X-XSS-Protection       "1; mode=block"
    -Server
    # HSTS убран — актуален только для HTTPS.
    # Включи когда перейдёшь на домен + TLS:
    # Strict-Transport-Security "max-age=31536000; includeSubDomains"
  }
}
