# =============================================================================
# Caddyfile — production reverse proxy для MAX University Event Bot
#
# Заполни DOMAIN в .env.prod:   DOMAIN=bot.youruniversity.ru
# Caddy автоматически получит TLS-сертификат от Let's Encrypt.
#
# Маршрутизация:
#   https://{DOMAIN}/              → Next.js admin panel (web:3000)
#   https://{DOMAIN}/api/*         → Next.js (web:3000, который прокидывает в bot:8081)
#   https://{DOMAIN}/webhook/max   → Go-бот (bot:8080, MAX hook)
#   http://{DOMAIN}                → редирект на https (автоматически в Caddy)
# =============================================================================

{$DOMAIN} {

  # ── Webhook MAX-бота ────────────────────────────────────────────────────
  # Должен быть ПЕРВЫМ — более специфичный префикс.
  handle /webhook/* {
    reverse_proxy bot:8080 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
    }
  }

  # ── Healthcheck бота (для мониторинга извне) ────────────────────────────
  handle /healthz {
    reverse_proxy bot:8080
  }

  # ── Всё остальное → Next.js ─────────────────────────────────────────────
  # Next.js сам прокидывает /api/* → bot:8081 через rewrites в next.config.mjs.
  handle {
    reverse_proxy web:3000 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
      # Если Next.js вернул 5xx — показываем страницу ошибки
      @error status 5xx
    }
  }

  # ── Логи (JSON для удобной выгрузки в мониторинг) ───────────────────────
  log {
    output stdout
    format json
    level  INFO
  }

  # ── Заголовки безопасности ───────────────────────────────────────────────
  header {
    # Блокировать отображение в iframe стороннего сайта
    X-Frame-Options           "SAMEORIGIN"
    # Запретить MIME-sniffing
    X-Content-Type-Options    "nosniff"
    # HSTS: 1 год
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    # Базовая CSP (кастомизируй под нужды)
    X-XSS-Protection          "1; mode=block"
    # Убрать Server-заголовок
    -Server
  }
}
