# =============================================================================
# Caddyfile — reference template (NOT used directly in production)
#
# deploy.sh auto-generates Caddyfile.gen based on DOMAIN:
#   IP address  → http://{$DOMAIN} (no TLS, port 80 only)
#   Domain name → {$DOMAIN} (HTTPS via Let's Encrypt, ports 80+443)
#
# This file is kept for reference. To change Caddy config, edit the
# generation logic in scripts/deploy.sh instead.
# =============================================================================

http://{$DOMAIN} {

  # ── Webhook MAX-бота ────────────────────────────────────────────────────
  handle /webhook/* {
    reverse_proxy bot:8080 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
    }
  }

  # ── Healthcheck ──────────────────────────────────────────────────────────
  handle /healthz {
    reverse_proxy bot:8080
  }

  # ── Всё остальное → Next.js ─────────────────────────────────────────────
  handle {
    reverse_proxy web:3000 {
      header_up X-Real-IP {remote_host}
      header_up X-Forwarded-For {remote_host}
    }
  }

  # ── Логи ─────────────────────────────────────────────────────────────────
  log {
    output stdout
    format json
    level  INFO
  }

  # ── Заголовки безопасности (HTTP-совместимые) ────────────────────────────
  header {
    X-Frame-Options        "SAMEORIGIN"
    X-Content-Type-Options "nosniff"
    X-XSS-Protection       "1; mode=block"
    -Server
    # HSTS убран — актуален только для HTTPS.
    # Включи когда перейдёшь на домен + TLS:
    # Strict-Transport-Security "max-age=31536000; includeSubDomains"
  }
}
